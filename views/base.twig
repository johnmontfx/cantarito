{% block html_head_container %}

{% include 'html-header.twig' %}
	{% block head %}
	{% endblock %}
	</head>
{% endblock %}

	<body class="{{body_class}}" data-template="base.twig">
		{{ function('wp_body_open') }}
		<a class="skip-link screen-reader-text" href="#content">{{ _e( 'Skip to content') }}</a>
			{% block header %}
				<header id="wrapper-navbar">
					<nav id="main-nav" class="navbar navbar-expand-md navbar-dark" aria-labelledby="main-nav-label">
						<div class="container">
							<a class="navbar-brand" rel="home" href="{{site.url}}" itemprop="url"><img id="site-logo" src="/wp-content/uploads/2023/03/logo-fxguide-159.png" alt="fxguide"></a>
							{% include "menu.twig" with {'items': menu.get_items} %}
						</div>
					</nav><!-- #nav -->
				</header>
			{% endblock %}
		</header>
		<div class="container-fluid" id="content" role="main" >
					{% block content %}
						Sorry, no content
					{% endblock %}

		</div>

		{% block footer %}
			<div class="container">
				<div class="row">
					<div class="col-md-12">
						<footer id="footer">
							{% include 'footer.twig' %}
						</footer>
						{{ function('wp_footer') }}
					</div><!--col end -->
				</div><!-- row end -->
			</div>
		{% endblock %}
	</body>
</html>
