{% if posts.pagination.pages is not empty %}
<div class="row justify-content-center">
    <div class="col-md-auto">
        <ul class="pagination">

            {# First #}
            {% if posts.pagination.pages|first and posts.pagination.pages|first.current != true %}
                <li class="first btn">
                    <a href="{{ posts.pagination.pages|first.link }}">First</a>
                </li>
            {% else %}
                <li class="first btn disabled">
                    First
                </li>
            {% endif %}

            {# Previous #}
            {% if posts.pagination.prev %}
                <li class="prev btn">
                    <a href="{{ posts.pagination.prev.link }}">Previous</a>
                </li>
            {% else %}
                <li class="prev btn disabled">
                    Previous
                </li>
            {% endif %}

            {# Pages #}
            {% for page in posts.pagination.pages %}
                {% if page.link %}
                    <li>
                        <a href="{{ page.link }}" class="btn {{ page.class }}">{{ page.title }}</a>
                    </li>
                {% else %}
                    <li class="current">
                        {% if page.class == 'dots' %}
                            <span class="btn {{ page.class }}"><i class="fa-solid fa-ellipsis"></i></span>
                        {% else %}
                            <span class="btn {{ page.class }}">{{ page.title }}</span>
                        {% endif %}
                    </li>
                {% endif %}
            {% endfor %}

            {# Next #}
            {% if posts.pagination.next %}
                <li class="next btn">
                    <a href="{{ posts.pagination.next.link }}">Next</a>
                </li>
            {% else %}
                <li class="next btn disabled">
                    Next
                </li>
            {% endif %}

            {# Last #}
            {% if posts.pagination.pages|last and posts.pagination.pages|last.current != true %}
                <li class="last btn">
                    <a href="{{ posts.pagination.pages|last.link }}">Last</a>
                </li>
            {% else %}
                <li class="last btn disabled">
                    Last
                </li>
            {% endif %}

        </ul>
    </div>
</div>
{% endif %}
